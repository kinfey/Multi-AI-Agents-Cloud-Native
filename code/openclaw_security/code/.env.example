# .env — AI Podcast Generator (fully automated)
# Fill in actual values after: cp .env.example .env

# ── Required ────────────────────────────────────────────────

# OpenClaw Gateway auth token (any random string)
OPENCLAW_TOKEN=change_me_to_a_random_secret_string

# SerpAPI Google Search Key
# Get key (free 250 calls/month): https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# ── Optional (has defaults) ─────────────────────────────────

# Number of podcast episodes to generate per run (top N trending topics)
# Default 1 = generate only the highest-trending episode
TOPICS_PER_RUN=1

# Scheduler interval in hours (0 = run once, no loop)
# Recommended: 6 = 4 episodes/day  |  24 = 1 episode/day
SCHEDULE_HOURS=24

# Skip SerpAPI DeepSearch (1=skip, saves quota, useful for testing)
SKIP_SEARCH=0
